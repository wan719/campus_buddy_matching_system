<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.swu.campus_buddy_matching_system.mapper.UserMapper">
    <!-- BaseResultMap for user properties -->
    <resultMap id="BaseResultMap" type="cn.edu.swu.campus_buddy_matching_system.model.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="email" property="email"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- Select users by condition -->
    <select id="selectByCondition" resultMap="BaseResultMap">
        SELECT id, username, password, email, enabled, created_at, updated_at
        FROM users
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="email != null and email != ''">
                AND email LIKE CONCAT('%', #{email}, '%')
            </if>
            <if test="enabled != null">
                AND enabled = #{enabled}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <!-- Select users by page -->
    <select id="selectByPage" resultMap="BaseResultMap">
        SELECT id, username, password, email, enabled, created_at, updated_at
        FROM users
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="email != null and email != ''">
                AND email LIKE CONCAT('%', #{email}, '%')
            </if>
            <if test="enabled != null">
                AND enabled = #{enabled}
            </if>
        </where>
        <choose>
            <when test="orderBy != null and orderBy != ''">
                ORDER BY ${orderBy}
                <choose>
                    <when test="orderDirection != null and (orderDirection == 'ASC' or orderDirection == 'DESC')">
                        ${orderDirection}
                    </when>
                    <otherwise>
                        ASC
                    </otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY created_at DESC
            </otherwise>
        </choose>
        <if test="pageSize != null and offset != null">
            LIMIT #{pageSize} OFFSET #{offset}
        </if>
    </select>

    <!-- Count users -->
    <select id="countUsers" resultType="int">
        SELECT COUNT(*)
        FROM users
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="email != null and email != ''">
                AND email LIKE CONCAT('%', #{email}, '%')
            </if>
            <if test="enabled != null">
                AND enabled = #{enabled}
            </if>
        </where>
    </select>

</mapper>